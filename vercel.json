{
  "version": 2,
  "name": "spms-frontend",
  "framework": "nextjs",
  "buildCommand": "cd web && npm ci && npm run build",
  "installCommand": "cd web && npm ci",
  "outputDirectory": "web/.next",
  "functions": {
    "web/app/**": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}